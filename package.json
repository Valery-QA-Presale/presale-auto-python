{
  "name": "service-automatization",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test --reporter=html --workers=1",
    "test:smoke": "npx playwright test --grep @smoke --reporter=html --workers=1",
    "test:b2c": "npx playwright test -c playwright.config.b2c.ts  --workers=1",
    "test:smoke:b2c": "npx playwright test tests/b2c/api/auth --reporter=html --workers=1",
    "test:b2b": "npx playwright test tests/b2b/api/auth --reporter=html --workers=1",
    "test:smoke:b2b": "npx playwright test tests/b2b/api/auth",
    "test:e2e": "playwright test --grep @e2e --reporter=html --workers=1",
    "test:headed": "npx playwright test --headed",
    "test:auth": "playwright test tests/b2c/api/auth/ --workers=1 --reporter=html",
    "test:profile": "playwright test tests/b2c/api/profile/ --workers=1 --reporter=html",
    "test:addresses": "playwright test tests/b2c/api/profile/addresses --workers=1 --reporter=html",
    "test:lots": "playwright test tests/b2c/api/lots --workers=1 --reporter=html",
    "test:catalog": "playwright test tests/b2c/api/catalog --workers=1 --reporter=html",
    "test:product": "playwright test tests/b2c/api/product --workers=1 --reporter=html",
    "report": "npx playwright show-report",
    "clean:reports": "rmdir /s /q playwright-report test-results",
    "format": "prettier --write \"tests/**/*.ts\" \"config/**/*.ts\"",
    "format:check": "prettier --check \"tests/**/*.ts\" \"config/**/*.ts\"",
    "lint": "eslint \"tests/**/*.ts\" --fix",
    "kill:allReps": "taskkill /F /IM node.exe 2>nul || echo 'No node processes'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "allure-playwright": "^3.4.2",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@b3nab/playwright-telegram-reporter": "^1.1.1",
    "@playwright/test": "^1.56.1",
    "@types/pg": "^8.16.0",
    "@wdio/cli": "^9.20.1",
    "ajv": "^8.18.0",
    "dotenv": "^17.3.1",
    "pg": "^8.16.3",
    "playwright": "^1.56.1",
    "webdriverio": "^9.20.1",
    "zod": "^4.3.6"
  }
}
