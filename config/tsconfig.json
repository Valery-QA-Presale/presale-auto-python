{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./tests",
    "resolveJsonModule": true
  },
  "paths": {
    "@/*": ["./src/*"],
    "@app/*": ["./src/app/*"],
    "@pages/*": ["./src/pages/*"],
    "@widgets/*": ["./src/widgets/*"],
    "@features/*": ["./src/features/*"],
    "@entities/*": ["./src/entities/*"],
    "@shared/*": ["./src/shared/*"]
  },
  "include": ["tests/**/*"],
  "exclude": ["node_modules", "dist"]
}